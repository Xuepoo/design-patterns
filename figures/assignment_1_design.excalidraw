      "id": "text_box_5",
      "type": "text",
      "x": 140,
      "y": 440,
      "width": 300,
      "height": 30,
      "text": "温度判定: 正常 20~30℃ | 异常低 <20℃ | 异常高 >30℃",
      "fontSize": 14,
      "fontFamily": 5,
      "strokeColor": "#e03131",
